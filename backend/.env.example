# PostgreSQL (read-only app user)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=querycraft_db
DB_USER=querycraft_user
DB_PASSWORD=your_readonly_password

# Allowed DB users (comma-separated) for Query Executor
ALLOWED_DB_USERS=querycraft_user

# LLM Provider: 'nvidia' (NVIDIA NIM, default) or 'ollama' for fully-offline generation
LLM_PROVIDER=nvidia

# NVIDIA NIM (OpenAI-compatible). Each model role carries its own API key.
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
PLANNER_MODEL=z-ai/glm-5.1
PLANNER_API_KEY=your_nvidia_planner_key
SQL_GENERATOR_MODEL=deepseek-ai/deepseek-v4-pro
SQL_GENERATOR_API_KEY=your_nvidia_generator_key
# Optional shared fallback used if a role-specific key is unset:
# NVIDIA_API_KEY=your_nvidia_key
# Optional multimodal model for /api/image-to-query (defaults to PLANNER_MODEL):
# NVIDIA_VISION_MODEL=z-ai/glm-5.1
# Sampling (deterministic defaults):
# PLANNER_TEMPERATURE=0.2
# PLANNER_TOP_P=0.9
# SQL_GENERATOR_TEMPERATURE=0.0
# SQL_GENERATOR_TOP_P=1.0

# Ollama (required when LLM_PROVIDER=ollama)
# OLLAMA_MODEL=llama3.1
# OLLAMA_URL=http://localhost:11434
# OLLAMA_TIMEOUT_SECONDS=120

# SQL dialect for query generation and validator lint.
# postgres (default) | sqlmx | sqlmp
SQL_DIALECT=postgres

# App settings
MAX_ROWS=10000
QUERY_TIMEOUT_SECONDS=120
CACHE_SIMILARITY_THRESHOLD=0.95
AUDIT_LOG_PATH=audit/query_log.db
SCHEMA_YAML_PATH=schema_store/enriched_schema.yaml
FEW_SHOTS_PATH=few_shots/examples.yaml

# Query cost guard — rejects queries whose PostgreSQL planner cost exceeds this value.
# 200000 allows complex CTE aggregations (e.g. 5-table joins with DATE_TRUNC).
# Raise further only if legitimate queries are still being blocked.
# MAX_QUERY_COST=200000

# Security
# querycraft_user is SELECT-only. statement_timeout=30s is the query safety net.

# Debug (set to true only during local development — exposes full LLM prompt in API responses)
# DEBUG_PROMPTS=false
