# PostgreSQL (read-only app user)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=querycraft_db
DB_USER=querycraft_user
DB_PASSWORD=your_readonly_password
DB_ADMIN_PASSWORD=371773

# Allowed DB users (comma-separated) for Query Executor
ALLOWED_DB_USERS=querycraft_user

# LLM Provider: 'gemini' (default) or 'ollama' for fully-offline generation
LLM_PROVIDER=gemini

# Gemini API (required when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite

# NVIDIA NIM API — required for the planner/generator models below
NVIDIA_API_KEY=your_nvidia_api_key

# Model roles. Any model name containing qwen/gpt/openai is routed to NVIDIA NIM;
# otherwise it falls back to Gemini. Both default to GEMINI_MODEL if unset.
PLANNER_MODEL=openai/gpt-oss-20b
SQL_GENERATOR_MODEL=qwen/qwen3-next-80b-a3b-instruct

# Ollama (required when LLM_PROVIDER=ollama)
# OLLAMA_MODEL=llama3.1
# OLLAMA_URL=http://localhost:11434
# OLLAMA_TIMEOUT_SECONDS=120

# App settings
MAX_ROWS=10000
QUERY_TIMEOUT_SECONDS=120
CACHE_SIMILARITY_THRESHOLD=0.95
AUDIT_LOG_PATH=audit/query_log.db
SCHEMA_YAML_PATH=schema_store/enriched_schema.yaml
FEW_SHOTS_PATH=few_shots/examples.yaml

# Query cost guard — rejects queries whose PostgreSQL planner cost exceeds this value.
# 200000 allows complex CTE aggregations (e.g. 5-table joins with DATE_TRUNC).
# Raise further only if legitimate queries are still being blocked.
# MAX_QUERY_COST=200000

# Security
# querycraft_user is SELECT-only. statement_timeout=30s is the query safety net.

# Debug (set to true only during local development — exposes full LLM prompt in API responses)
# DEBUG_PROMPTS=false
