# PostgreSQL (read-only app user)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=querycraft_db
DB_USER=querycraft_user
DB_PASSWORD=your_readonly_password

# Allowed DB users (comma-separated) for Query Executor
ALLOWED_DB_USERS=querycraft_user

# Ollama — local LLM for SQL generation.
# Requires `ollama serve` running and the model pulled (`ollama list`).
OLLAMA_MODEL=gemma4-sql
OLLAMA_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=600

# App settings
MAX_ROWS=10000
QUERY_TIMEOUT_SECONDS=120
CACHE_SIMILARITY_THRESHOLD=0.95
AUDIT_LOG_PATH=audit/query_log.db
SCHEMA_YAML_PATH=schema_store/enriched_schema.yaml
FEW_SHOTS_PATH=few_shots/examples.yaml

# Security
# querycraft_user is SELECT-only. statement_timeout=30s is the query safety net.
